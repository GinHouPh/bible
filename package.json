{
  "name": "bible-app",
  "version": "1.0.0",
  "description": "Cross-platform Bible application with advanced study tools",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:mobile\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:mobile": "cd apps/mobile && npm run start",
    "dev:desktop": "cd apps/desktop && npm run dev",
    "build": "npm run build:shared && npm run build:web && npm run build:mobile",
    "build:shared": "cd packages/shared && npm run build",
    "build:web": "cd apps/web && npm run build",
    "build:mobile": "cd apps/mobile && npm run build",
    "build:desktop": "cd apps/desktop && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf node_modules apps/*/node_modules packages/*/node_modules",
    "setup": "npm install && npm run setup:apps && npm run setup:packages",
    "setup:apps": "cd apps/web && npm install && cd ../mobile && npm install && cd ../desktop && npm install",
    "setup:packages": "cd packages/shared && npm install && cd ../bible-parser && npm install && cd ../database && npm install"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "concurrently": "^8.2.1",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GinHouPh/bible.git"
  },
  "keywords": [
    "bible",
    "cross-platform",
    "react-native",
    "nextjs",
    "electron",
    "study-tools",
    "usfm"
  ],
  "author": "GinHouPh",
  "license": "MIT"
}
